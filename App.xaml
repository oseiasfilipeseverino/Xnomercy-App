<Application x:Class="XnomercyApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:XnomercyApp"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Mesmas fontes do site: Teko (títulos) e Barlow (corpo) -->
        <FontFamily x:Key="FontHead">pack://application:,,,/Fonts/#Teko</FontFamily>
        <FontFamily x:Key="FontBody">pack://application:,,,/Fonts/#Barlow</FontFamily>
    </Application.Resources>
</Application>
