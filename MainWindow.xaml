<Window x:Class="XnomercyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:local="clr-namespace:XnomercyApp"
        mc:Ignorable="d"
        Title="XnoMercy" Height="800" Width="1280"
        Background="#080808"
        FontFamily="{StaticResource FontBody}"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <Window.Resources>
        <local:PctToWidthConverter x:Key="PctToWidth"/>
        <!-- Sobrescreve o hover/seleção branco padrão do Windows nas listas (Loot Log,
             Medidor de Dano etc.) por algo que combina com o tema escuro do app. -->
        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1a1a1a"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#262626"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="NavBtn">
            <Setter Property="Foreground" Value="#cbd5e1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" Padding="22,13">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1a1a1a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Botão de abrir/fechar o menu lateral — diferente do NavBtn (que alinha à
             esquerda com padding grande): aqui o conteúdo fica centralizado, senão o
             "☰" ficava quase saindo da borda quando a barra estava fechada (coluna de
             só 48px de largura), parecendo cortado/torto. -->
        <Style TargetType="Button" x:Key="ToggleBtn">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1a1a1a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Banner de atualização disponível (some por padrão) -->
        <Border x:Name="UpdateBanner" Grid.Row="0" Background="#1f5b2e" Visibility="Collapsed">
            <Grid Margin="16,8,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="UpdateBannerText" Grid.Column="0" Text="" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                <Button x:Name="BtnUpdateDownload" Grid.Column="1" Content="Reiniciar e atualizar" Click="BtnUpdateDownload_Click"
                        Padding="12,5" Background="#0f0f0f" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="BtnUpdateDismiss" Grid.Column="2" Content="✕" Click="BtnUpdateDismiss_Click"
                        Padding="10,5" Margin="8,0,0,0" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarCol" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Menu lateral (aparece só depois do login) -->
        <Border x:Name="Sidebar" Grid.Column="0" Background="#0f0f0f" BorderBrush="#2a1515" BorderThickness="0,0,1,0" Visibility="Collapsed">
            <DockPanel LastChildFill="False">
                <Button x:Name="BtnToggleSidebar" DockPanel.Dock="Top" Content="☰" Click="ToggleSidebar_Click"
                        Style="{StaticResource ToggleBtn}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <StackPanel x:Name="SidebarTop" DockPanel.Dock="Top">
                    <TextBlock Text="XNOMERCY" Foreground="#c9a227" FontFamily="{StaticResource FontHead}" FontWeight="SemiBold" FontSize="26" Margin="22,4,22,14"/>
                    <Border Height="1" Background="#2a1515" Margin="16,0,16,10"/>
                    <Button x:Name="NavFame"   Content="Fama &amp; Prata" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="fame"/>
                    <Button x:Name="NavLoot"   Content="Loot Log"        Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="loot"/>
                    <Button x:Name="NavDamage" Content="Medidor de Dano"  Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="damage"/>
                    <Button x:Name="NavCraft"  Content="Craft"           Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="craft"/>
                </StackPanel>
                <StackPanel x:Name="SidebarBottom" DockPanel.Dock="Bottom" Margin="22,0,22,18">
                    <!-- Captura acessível de qualquer aba, não só do Loot Log — pra não
                         precisar entrar lá só pra iniciar/pausar. -->
                    <Button x:Name="BtnCaptureToggle" Content="Iniciar captura" Click="BtnCaptureToggle_Click"
                            Padding="0,10" Background="#dc2626" Foreground="White" BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Button x:Name="BtnPauseToggle" Content="Pausar" Click="BtnPauseToggle_Click"
                            Padding="0,7" Background="#262626" Foreground="White" BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,0,12"/>
                    <Border Height="1" Background="#2a1515" Margin="-6,0,-6,12"/>
                    <Button x:Name="BtnLogout" Content="Sair" Click="BtnLogout_Click" HorizontalAlignment="Left"
                            Padding="0" Margin="0,0,0,10" Background="Transparent" Foreground="#dc2626" FontSize="13" Cursor="Hand" BorderThickness="0"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="CaptureDot" Width="9" Height="9" Fill="#666666" VerticalAlignment="Center"/>
                        <TextBlock x:Name="CaptureStateLabel" Text="Captura parada" Foreground="#888888" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Timer de fechamento de entrada de dungeon aleatória (90s) — visível
                         de qualquer aba, igual o indicador de captura acima. Some quando
                         você sai da dungeon. Ver DungeonTimerTracker.cs. -->
                    <Border x:Name="PanelDungeonTimer" Visibility="Collapsed" Background="#1a1208" CornerRadius="6"
                            Padding="10,8" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="ENTRADA DA DUNGEON FECHA EM" Foreground="#c9a227" FontSize="10" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtDungeonTimer" Text="01:30" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Conteúdo -->
        <Grid Grid.Column="1">
            <wv2:WebView2 x:Name="WebView" Visibility="Visible"/>

            <!-- Marca enquanto a tela de login do site carrega (some no 1º carregamento) -->
            <Grid x:Name="LoginLoading" Background="#080808">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="XNOMERCY" FontFamily="{StaticResource FontHead}" FontSize="46" Foreground="#c9a227" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Carregando..." Foreground="#888888" FontSize="14" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Pedido único de consentimento pro envio de diagnóstico (fase de teste).
                 Some pra sempre depois da 1ª resposta (ver ConsentStore). -->
            <Grid x:Name="PanelConsent" Visibility="Collapsed" Background="#080808">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="520">
                    <TextBlock Text="XNOMERCY" FontFamily="{StaticResource FontHead}" FontSize="30" Foreground="#c9a227" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Foreground="#cbd5e1" FontSize="14" Margin="0,18,0,0" TextWrapping="Wrap" TextAlignment="Center"
                               Text="Enquanto estamos testando, o app pode enviar erros e os eventos do Albion capturados (mesma informação do Loot Log / Medidor de Dano / Fama &amp; Prata) pro Discord da guild, pra ajudar a calibrar. Nada do seu sistema ou arquivos pessoais — só o que é do app e do jogo."/>
                    <TextBlock Foreground="#6b7280" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" TextAlignment="Center"
                               Text="Só pergunta isso uma vez. Pode mudar de ideia depois falando com a liderança."/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button x:Name="BtnConsentYes" Content="Aceitar" Click="BtnConsentYes_Click"
                                Padding="18,8" Background="#dc2626" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="BtnConsentNo" Content="Não aceitar" Click="BtnConsentNo_Click"
                                Padding="18,8" Margin="10,0,0,0" Background="#262626" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Grid x:Name="PanelLoot" Visibility="Collapsed" Background="#080808">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="16,12,16,8">
                    <TextBlock Text="Loot Log" Foreground="#c9a227" FontFamily="{StaticResource FontHead}" FontSize="26" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <!-- Iniciar/Pausar captura agora fica no menu lateral, acima do "Sair"
                             — acessível de qualquer aba, não só daqui. -->
                        <TextBlock x:Name="TxtCaptureStatus" Text="Parado" Foreground="#888888" VerticalAlignment="Center"/>
                        <Button x:Name="BtnExportCsv" Content="Exportar CSV" Click="BtnExportCsv_Click"
                                Padding="14,6" Background="#181818" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="20,0,0,0"/>
                        <Button x:Name="BtnLootReset" Content="Reiniciar sessão" Click="BtnLootReset_Click"
                                Padding="14,6" Background="#262626" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="8,0,0,0"/>
                        <ToggleButton x:Name="BtnAdvancedMode" Content="Modo avançado" Click="BtnAdvancedMode_Click"
                                      Padding="14,6" Background="#262626" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="8,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <CheckBox x:Name="ChkHideMob" Content="Esconder saque de monstro" IsChecked="False" Click="LootFilter_Changed"
                                  Foreground="#cbd5e1" VerticalAlignment="Center"/>
                        <CheckBox x:Name="ChkGuildOnlyLoot" Content="Só minha guild" IsChecked="False" Click="LootFilter_Changed"
                                  Foreground="#cbd5e1" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        <CheckBox x:Name="ChkPartyOnlyLoot" Content="Só meu grupo" IsChecked="False" Click="LootFilter_Changed"
                                  Foreground="#cbd5e1" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Visão limpa (padrão): feed social de loot (evento 277) -->
                <ListView x:Name="ListCleanLoot" Grid.Row="1" Margin="16,0,16,16" Background="#0f0f0f" Foreground="White" BorderThickness="0" FontSize="14">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Hora" Width="90" DisplayMemberBinding="{Binding Time}"/>
                            <GridViewColumn Header="Quem pegou" Width="150" DisplayMemberBinding="{Binding Looter}"/>
                            <GridViewColumn Header="" Width="40">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding ItemIcon}" Width="32" Height="32"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Item" Width="300" DisplayMemberBinding="{Binding Item}"/>
                            <GridViewColumn Header="De quem" Width="150" DisplayMemberBinding="{Binding From}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Modo avançado (oculto por padrão): dados brutos pra depuração -->
                <Grid x:Name="PanelAdvanced" Grid.Row="1" Visibility="Collapsed" Background="#080808">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto" MaxHeight="220"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Foreground="#888888" FontSize="12" TextWrapping="Wrap"
                                   Text="Mostrando todos os eventos de rede decodificados, sem filtro. Clique no botão dourado bem na hora que pegar o item — os eventos próximos ficam fixos na caixa verde abaixo."/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button x:Name="BtnMarkMoment" Content="📍 Marquei o momento!" Click="BtnMarkMoment_Click"
                                    Padding="14,6" Background="#c9a227" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                            <Button x:Name="BtnClearMarked" Content="Limpar marcados" Click="BtnClearMarked_Click"
                                    Padding="14,6" Background="#262626" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#0d1f12" BorderBrush="#181818" BorderThickness="1" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="📍 Eventos marcados (candidatos a loot)" Foreground="#4ade80" FontWeight="Bold" Margin="8,6,8,4"/>
                            <ListView x:Name="ListMarkedEvents" Grid.Row="1" Background="Transparent" Foreground="White" BorderThickness="0" MaxHeight="180">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Hora" Width="100" DisplayMemberBinding="{Binding Time}"/>
                                        <GridViewColumn Header="Code" Width="60" DisplayMemberBinding="{Binding Code}"/>
                                        <GridViewColumn Header="Parâmetros" Width="900" DisplayMemberBinding="{Binding Summary}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>

                    <ListView x:Name="ListLootEvents" Grid.Row="2" Background="#0f0f0f" Foreground="White" BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNearMark}" Value="True">
                                        <Setter Property="Background" Value="#181818"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Hora" Width="100" DisplayMemberBinding="{Binding Time}"/>
                                <GridViewColumn Header="Code" Width="60" DisplayMemberBinding="{Binding Code}"/>
                                <GridViewColumn Header="Parâmetros" Width="900" DisplayMemberBinding="{Binding Summary}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Grid>

            <Grid x:Name="PanelDamage" Visibility="Collapsed" Background="#080808">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="16,12,16,8">
                    <TextBlock Text="Medidor de Dano — sessão atual" Foreground="#c9a227" FontFamily="{StaticResource FontHead}" FontSize="26" FontWeight="SemiBold"/>
                    <TextBlock Foreground="#888888" FontSize="12" Margin="0,4,0,8" TextWrapping="Wrap"
                               Text="Ranking de dano e cura por jogador, do que mais deu dano para o que menos deu. O nome é resolvido pra todo jogador por perto (até quem já estava na cena); o que sobrar como #número costuma ser mob ou invocação."/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnDamageReset" Content="Reiniciar sessão" Click="BtnDamageReset_Click"
                                Padding="14,6" Background="#262626" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="BtnDamageCopy" Content="Copiar medidor" Click="BtnDamageCopy_Click"
                                Padding="14,6" Background="#181818" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="8,0,0,0"/>
                        <CheckBox x:Name="ChkShowUnnamed" Content="Mostrar sem nome (#número)" IsChecked="False" Click="DamageFilter_Changed"
                                  Foreground="#cbd5e1" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        <CheckBox x:Name="ChkGuildOnlyDamage" Content="Só minha guild" IsChecked="False" Click="DamageFilter_Changed"
                                  Foreground="#cbd5e1" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        <CheckBox x:Name="ChkPartyOnlyDamage" Content="Só meu grupo" IsChecked="False" Click="DamageFilter_Changed"
                                  Foreground="#cbd5e1" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                </StackPanel>
                <Grid Grid.Row="1" Margin="16,0,16,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="360"/>
                    </Grid.ColumnDefinitions>
                    <ListView x:Name="ListDamage" Grid.Column="0" Margin="0,0,8,0" Background="#0f0f0f" Foreground="White" BorderThickness="0"
                              SelectionChanged="ListDamage_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="" Width="40">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding WeaponIcon}" Width="30" Height="30"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Jogador" Width="200" DisplayMemberBinding="{Binding Player}"/>
                                <GridViewColumn Header="Dano" Width="100" DisplayMemberBinding="{Binding Damage}"/>
                                <GridViewColumn Header="% Dano" Width="200">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="60"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Barra: estilo simples sem chrome do Windows (fundo escuro,
                                                     preenchimento dourado proporcional a DamagePctValue). -->
                                                <Border Grid.Column="0" Background="#1a1a1a" CornerRadius="3" Height="14" VerticalAlignment="Center">
                                                    <Border HorizontalAlignment="Left" Background="#c9a227" CornerRadius="3"
                                                            Width="{Binding DamagePctValue, Converter={StaticResource PctToWidth}}"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding DamagePct}" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="White"/>
                                            </Grid>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Cura" Width="100" DisplayMemberBinding="{Binding Healing}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Quebra de dano por habilidade (estilo Albion Battle Analytics) do
                         jogador selecionado na lista à esquerda — ver DamageMeterTracker.
                         SnapshotBySpell e SpellCatalog (resolve o índice da skill pro nome). -->
                    <Border Grid.Column="1" Background="#0f0f0f" CornerRadius="6" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="TxtDamageBySkillTitle" Grid.Row="0" Text="Dano por habilidade — selecione um jogador na lista"
                                       Foreground="#cbd5e1" FontWeight="SemiBold" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <ListView x:Name="ListDamageBySkill" Grid.Row="1" Background="Transparent" Foreground="White" BorderThickness="0">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Habilidade" Width="170" DisplayMemberBinding="{Binding Name}"/>
                                        <GridViewColumn Header="Dano" Width="80" DisplayMemberBinding="{Binding Damage}"/>
                                        <GridViewColumn Header="%" Width="60" DisplayMemberBinding="{Binding DamagePct}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Mostrado quando a conta de teste não tem permissão pra essa aba -->
            <Grid x:Name="PanelBlocked" Visibility="Collapsed" Background="#080808">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="600">
                    <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="VOCÊ ESTÁ BLOQUEADO DE ACESSAR ESSA PARTE!" Foreground="#dc2626"
                               FontFamily="{StaticResource FontHead}" FontSize="30" FontWeight="SemiBold"
                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,16,0,0"/>
                    <TextBlock Text="Fale com a liderança da guild se precisar de acesso." Foreground="#888888"
                               FontSize="13" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>

            <Grid x:Name="PanelFame" Visibility="Collapsed" Background="#080808">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Fama &amp; Prata" Foreground="#c9a227" FontFamily="{StaticResource FontHead}" FontSize="32" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtFameSessionStart" Foreground="#888888" FontSize="12" Margin="0,4,0,16" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Background="#0f0f0f" CornerRadius="6" Padding="22,16" Margin="0,0,12,0">
                            <StackPanel>
                                <Image Source="Icons/fame.png" Width="26" Height="26" HorizontalAlignment="Center"/>
                                <TextBlock Text="FAMA VERMELHA" Foreground="#888888" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                <TextBlock x:Name="TxtFameTotal" Text="0" Foreground="#f87171" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#0f0f0f" CornerRadius="6" Padding="22,16" Margin="0,0,12,0">
                            <StackPanel>
                                <Image Source="Icons/yellow_fame.png" Width="26" Height="26" HorizontalAlignment="Center"/>
                                <TextBlock Text="FAMA AMARELA" Foreground="#888888" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                <TextBlock x:Name="TxtYellowFameTotal" Text="—" Foreground="#fde047" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#0f0f0f" CornerRadius="6" Padding="22,16" Margin="0,0,12,0">
                            <StackPanel>
                                <Image Source="Icons/silver.png" Width="26" Height="26" HorizontalAlignment="Center"/>
                                <TextBlock Text="PRATA" Foreground="#888888" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                <TextBlock x:Name="TxtSilverTotal" Text="0" Foreground="#e2e8f0" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Mobs mortos em mundo aberto (Task #2) — ver OpenWorldKillTracker.cs.
                             Conta pelo evento MobKilled (166), já calibrado, filtrando pelo
                             nome de quem deu o último hit = você. -->
                        <Border Background="#0f0f0f" CornerRadius="6" Padding="22,16">
                            <StackPanel>
                                <TextBlock Text="⚔️" FontSize="22" HorizontalAlignment="Center"/>
                                <TextBlock Text="MOBS MORTOS" Foreground="#888888" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                <TextBlock x:Name="TxtMobKillsTotal" Text="0" Foreground="#86efac" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtMobKillsPerHour" Text="0/hora" Foreground="#6b7280" FontSize="11" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <Button x:Name="BtnFameReset" Content="Reiniciar sessão" Click="BtnFameReset_Click"
                            Padding="14,6" Margin="0,20,0,0" Background="#262626" Foreground="White" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtFameHint" Foreground="#6b7280" FontSize="11" Margin="0,16,0,0" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="440"
                               Text="Fama amarela (facção/standing) ainda em calibração — me diga de qual conteúdo ela vem pra eu achar o código."/>

                    <!-- Quebra de mobs mortos por tipo — só aparece depois do 1º kill. -->
                    <ListView x:Name="ListMobKills" Margin="0,20,0,0" MaxHeight="220" Width="440"
                              Background="#0f0f0f" Foreground="White" BorderThickness="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Mob" Width="280" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Mortes" Width="80" DisplayMemberBinding="{Binding Kills}"/>
                                <GridViewColumn Header="/hora" Width="70" DisplayMemberBinding="{Binding KillsPerHour}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </Grid>
        </Grid>
        </Grid>

        <!-- Ícone da bandeja do sistema -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                         ToolTipText="XnoMercy"
                         IconSource="icon.ico"
                         TrayMouseDoubleClick="TrayIcon_DoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Abrir" Click="TrayIcon_DoubleClick"/>
                    <MenuItem Header="Sair" Click="TrayMenu_Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
