<Window x:Class="XnomercyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:local="clr-namespace:XnomercyApp"
        mc:Ignorable="d"
        Title="XnoMercy" Height="800" Width="1280"
        Background="#131313"
        FontFamily="{StaticResource FontBody}"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <Window.Resources>
        <local:PctToWidthConverter x:Key="PctToWidth"/>
        <!-- Sobrescreve o hover/seleção branco padrão do Windows nas listas (Loot Log,
             Medidor de Dano etc.) por algo que combina com o tema escuro do app. -->
        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#242424"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2e2e2e"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="NavBtn">
            <Setter Property="Foreground" Value="#8CFFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="BgFill" Grid.ColumnSpan="2" Background="Transparent"/>
                            <Border x:Name="Accent" Grid.Column="0" Background="Transparent"/>
                            <ContentPresenter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="17,11,17,11"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgFill" Property="Background" Value="#222222"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}" Value="#292213">
                                <Setter TargetName="BgFill" Property="Background" Value="#292213"/>
                                <Setter TargetName="Accent" Property="Background" Value="#c9a227"/>
                                <Setter Property="Foreground" Value="#DEFFFFFF"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Botão de abrir/fechar o menu lateral — diferente do NavBtn (que alinha à
             esquerda com padding grande): aqui o conteúdo fica centralizado, senão o
             "☰" ficava quase saindo da borda quando a barra estava fechada (coluna de
             só 48px de largura), parecendo cortado/torto. -->
        <Style TargetType="Button" x:Key="ToggleBtn">
            <Setter Property="Foreground" Value="#8CFFFFFF"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#242424"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Banner de atualização disponível (some por padrão) -->
        <Border x:Name="UpdateBanner" Grid.Row="0" Background="#1f5b2e" Visibility="Collapsed">
            <Grid Margin="16,8,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="UpdateBannerText" Grid.Column="0" Text="" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                <Button x:Name="BtnUpdateDownload" Grid.Column="1" Content="Reiniciar e atualizar" Click="BtnUpdateDownload_Click"
                        Padding="12,5" Background="#1b1b1b" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="BtnUpdateDismiss" Grid.Column="2" Content="✕" Click="BtnUpdateDismiss_Click"
                        Padding="10,5" Margin="8,0,0,0" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarCol" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Menu lateral (aparece só depois do login) -->
        <Border x:Name="Sidebar" Grid.Column="0" Background="#1b1b1b" BorderBrush="#2b2b2b" BorderThickness="0,0,1,0" Visibility="Collapsed">
            <DockPanel LastChildFill="False">
                <Button x:Name="BtnToggleSidebar" DockPanel.Dock="Top" Content="☰" Click="ToggleSidebar_Click"
                        Style="{StaticResource ToggleBtn}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <StackPanel x:Name="SidebarTop" DockPanel.Dock="Top">
                    <TextBlock Text="XNOMERCY" Foreground="#c9a227" FontFamily="{StaticResource FontHead}" FontWeight="SemiBold" FontSize="28" Margin="20,6,20,12"/>
                    <Border Height="1" Margin="0,0,0,10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#c9a227" Offset="0"/>
                                <GradientStop Color="#3a2c0d" Offset="0.55"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Button x:Name="NavFame" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="fame">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="★" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" Opacity=".45"/><TextBlock Text="Fama &amp; Prata" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button x:Name="NavLoot" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="loot">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="▦" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" Opacity=".45"/><TextBlock Text="Loot Log" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button x:Name="NavDamage" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="damage">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="⚔" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" Opacity=".45"/><TextBlock Text="Medidor de Dano" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button x:Name="NavCraft" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="craft">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="⚒" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" Opacity=".45"/><TextBlock Text="Craft" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button x:Name="NavSessions" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="sessions">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="🕘" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" Opacity=".45"/><TextBlock Text="Sessões" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel x:Name="SidebarBottom" DockPanel.Dock="Bottom" Margin="22,0,22,18">
                    <!-- Captura acessível de qualquer aba, não só do Loot Log — pra não
                         precisar entrar lá só pra iniciar/pausar. -->
                    <Button x:Name="BtnCaptureToggle" Content="Iniciar captura" Click="BtnCaptureToggle_Click"
                            Padding="0,10" Background="#c9a227" Foreground="#111111" BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Button x:Name="BtnPauseToggle" Content="Pausar" Click="BtnPauseToggle_Click"
                            Padding="0,7" Background="#2e2e2e" Foreground="White" BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,0,8"/>
                    <Button x:Name="BtnOverlayToggle" Content="Overlay" Click="BtnOverlayToggle_Click"
                            Padding="0,7" Background="#2e2e2e" Foreground="White" BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,0,12"
                            ToolTip="Mini painel flutuante com fama/prata por hora, sempre visível por cima do jogo"/>
                    <Border Height="1" Margin="-6,0,-6,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#2b2b2b" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Button x:Name="BtnLogout" Content="Sair" Click="BtnLogout_Click" HorizontalAlignment="Left"
                            Padding="0" Margin="0,0,0,10" Background="Transparent" Foreground="#8CFFFFFF" FontSize="13" Cursor="Hand" BorderThickness="0"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="CaptureDot" Width="9" Height="9" Fill="#57FFFFFF" VerticalAlignment="Center"/>
                        <TextBlock x:Name="CaptureStateLabel" Text="Captura parada" Foreground="#8CFFFFFF" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Timer de fechamento de entrada de dungeon aleatória (90s) — visível
                         de qualquer aba, igual o indicador de captura acima. Some quando
                         você sai da dungeon. Ver DungeonTimerTracker.cs. -->
                    <Border x:Name="PanelDungeonTimer" Visibility="Collapsed" Background="#1a1208" CornerRadius="6"
                            Padding="10,8" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="ENTRADA DA DUNGEON FECHA EM" Foreground="#c9a227" FontSize="10" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtDungeonTimer" Text="01:30" Foreground="White" FontFamily="{StaticResource FontHead}" FontSize="24" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Conteúdo -->
        <Grid Grid.Column="1">
            <wv2:WebView2 x:Name="WebView" Visibility="Visible"/>

            <!-- Marca enquanto a tela de login do site carrega (some no 1º carregamento) -->
            <Grid x:Name="LoginLoading" Background="#131313">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                    <TextBlock Text="XNOMERCY" FontFamily="{StaticResource FontHead}" FontSize="46" Foreground="#c9a227" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtLoginLoadingStatus" Text="Carregando..." Foreground="#8CFFFFFF" FontSize="14" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Pedido único de consentimento pro envio de diagnóstico (fase de teste).
                 Some pra sempre depois da 1ª resposta (ver ConsentStore). -->
            <Grid x:Name="PanelConsent" Visibility="Collapsed" Background="#131313">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="520">
                    <TextBlock Text="XNOMERCY" FontFamily="{StaticResource FontHead}" FontSize="30" Foreground="#c9a227" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Foreground="#DEFFFFFF" FontSize="14" Margin="0,18,0,0" TextWrapping="Wrap" TextAlignment="Center"
                               Text="Enquanto estamos testando, o app pode enviar erros e os eventos do Albion capturados (mesma informação do Loot Log / Medidor de Dano / Fama &amp; Prata) pro Discord da guild, pra ajudar a calibrar. Nada do seu sistema ou arquivos pessoais — só o que é do app e do jogo."/>
                    <TextBlock Foreground="#8CFFFFFF" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" TextAlignment="Center"
                               Text="Só pergunta isso uma vez. Pode mudar de ideia depois falando com a liderança."/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button x:Name="BtnConsentYes" Content="Aceitar" Click="BtnConsentYes_Click"
                                Padding="18,8" Background="#c9a227" Foreground="#111111" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="BtnConsentNo" Content="Não aceitar" Click="BtnConsentNo_Click"
                                Padding="18,8" Margin="10,0,0,0" Background="#2e2e2e" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Grid x:Name="PanelLoot" Visibility="Collapsed" Background="#131313">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="16,12,16,8">
                    <TextBlock Text="Loot Log" Foreground="#c9a227" FontFamily="{StaticResource FontHead}" FontSize="26" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <!-- Iniciar/Pausar captura agora fica no menu lateral, acima do "Sair"
                             — acessível de qualquer aba, não só daqui. -->
                        <TextBlock x:Name="TxtCaptureStatus" Text="Parado" Foreground="#8CFFFFFF" VerticalAlignment="Center"/>
                        <Button x:Name="BtnExportCsv" Content="Exportar CSV" Click="BtnExportCsv_Click"
                                Padding="14,6" Background="#242424" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="20,0,0,0"/>
                        <Button x:Name="BtnLootReset" Content="Reiniciar sessão" Click="BtnLootReset_Click"
                                Padding="14,6" Background="#2e2e2e" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="8,0,0,0"/>
                        <ToggleButton x:Name="BtnAdvancedMode" Content="Modo avançado" Click="BtnAdvancedMode_Click"
                                      Padding="14,6" Background="#2e2e2e" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="8,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <CheckBox x:Name="ChkHideMob" Content="Esconder saque de monstro" IsChecked="False" Click="LootFilter_Changed"
                                  Foreground="#DEFFFFFF" VerticalAlignment="Center"/>
                        <CheckBox x:Name="ChkGuildOnlyLoot" Content="Só minha guild" IsChecked="False" Click="LootFilter_Changed"
                                  Foreground="#DEFFFFFF" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        <CheckBox x:Name="ChkPartyOnlyLoot" Content="Só meu grupo" IsChecked="False" Click="LootFilter_Changed"
                                  Foreground="#DEFFFFFF" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Visão limpa (padrão): feed estilo chat "Fulano pegou X de Y" -->
                <ListView x:Name="ListCleanLoot" Grid.Row="1" Margin="16,0,16,16" Background="#1b1b1b" Foreground="White" BorderThickness="0" FontSize="13">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="66"/>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Time}" Foreground="#3d3d3d" FontSize="10"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <Image Grid.Column="1" Source="{Binding ItemIcon}" Width="22" Height="22"
                                       VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="8,0,10,0"
                                           FontSize="12" TextTrimming="CharacterEllipsis">
                                    <Run Text="{Binding Looter, Mode=OneWay}" FontWeight="SemiBold" Foreground="#DEFFFFFF"/>
                                    <Run Text=" pegou " Foreground="#57FFFFFF"/>
                                    <Run Text="{Binding Item, Mode=OneWay}" Foreground="#c9a227"/>
                                    <Run Text=" de " Foreground="#57FFFFFF"/>
                                    <Run Text="{Binding From, Mode=OneWay}" Foreground="#57FFFFFF"/>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Modo avançado (oculto por padrão): dados brutos pra depuração -->
                <Grid x:Name="PanelAdvanced" Grid.Row="1" Visibility="Collapsed" Background="#131313">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto" MaxHeight="220"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Foreground="#8CFFFFFF" FontSize="12" TextWrapping="Wrap"
                                   Text="Mostrando todos os eventos de rede decodificados, sem filtro. Clique no botão dourado bem na hora que pegar o item — os eventos próximos ficam fixos na caixa verde abaixo."/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button x:Name="BtnMarkMoment" Content="📍 Marquei o momento!" Click="BtnMarkMoment_Click"
                                    Padding="14,6" Background="#c9a227" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                            <Button x:Name="BtnClearMarked" Content="Limpar marcados" Click="BtnClearMarked_Click"
                                    Padding="14,6" Background="#2e2e2e" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#0d1f12" BorderBrush="#242424" BorderThickness="1" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="📍 Eventos marcados (candidatos a loot)" Foreground="#4ade80" FontWeight="Bold" Margin="8,6,8,4"/>
                            <ListView x:Name="ListMarkedEvents" Grid.Row="1" Background="Transparent" Foreground="White" BorderThickness="0" MaxHeight="180">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Hora" Width="100" DisplayMemberBinding="{Binding Time}"/>
                                        <GridViewColumn Header="Code" Width="60" DisplayMemberBinding="{Binding Code}"/>
                                        <GridViewColumn Header="Parâmetros" Width="900" DisplayMemberBinding="{Binding Summary}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>

                    <ListView x:Name="ListLootEvents" Grid.Row="2" Background="#1b1b1b" Foreground="White" BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNearMark}" Value="True">
                                        <Setter Property="Background" Value="#242424"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Hora" Width="100" DisplayMemberBinding="{Binding Time}"/>
                                <GridViewColumn Header="Code" Width="60" DisplayMemberBinding="{Binding Code}"/>
                                <GridViewColumn Header="Parâmetros" Width="900" DisplayMemberBinding="{Binding Summary}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Grid>

            <Grid x:Name="PanelDamage" Visibility="Collapsed" Background="#131313">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="16,12,16,8">
                    <TextBlock Text="Medidor de Dano — sessão atual" Foreground="#c9a227" FontFamily="{StaticResource FontHead}" FontSize="28" FontWeight="SemiBold"/>
                    <TextBlock Foreground="#8CFFFFFF" FontSize="12" Margin="0,4,0,8" TextWrapping="Wrap"
                               Text="Ranking de dano e cura por jogador, do que mais deu dano para o que menos deu. O nome é resolvido pra todo jogador por perto (até quem já estava na cena); o que sobrar como #número costuma ser mob ou invocação."/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnDamageReset" Content="Reiniciar sessão" Click="BtnDamageReset_Click"
                                Padding="14,6" Background="#2e2e2e" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="BtnDamageCopy" Content="Copiar medidor" Click="BtnDamageCopy_Click"
                                Padding="14,6" Background="#242424" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="8,0,0,0"/>
                        <CheckBox x:Name="ChkShowUnnamed" Content="Mostrar sem nome (#número)" IsChecked="False" Click="DamageFilter_Changed"
                                  Foreground="#DEFFFFFF" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        <CheckBox x:Name="ChkGuildOnlyDamage" Content="Só minha guild" IsChecked="False" Click="DamageFilter_Changed"
                                  Foreground="#DEFFFFFF" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        <CheckBox x:Name="ChkPartyOnlyDamage" Content="Só meu grupo" IsChecked="False" Click="DamageFilter_Changed"
                                  Foreground="#DEFFFFFF" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                </StackPanel>
                <Grid Grid.Row="1" Margin="16,0,16,16">
                    <!-- Skill panel agora é overlay flutuante (Panel.ZIndex="10") -->
                    <ListView x:Name="ListDamage" Background="#1b1b1b" Foreground="White" BorderThickness="0"
                              SelectionChanged="ListDamage_SelectionChanged">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="ListDamageItem_PreviewMouseDown"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="" Width="40">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding WeaponIcon}" Width="30" Height="30"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Jogador" Width="200" DisplayMemberBinding="{Binding Player}"/>
                                <GridViewColumn Header="Dano" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Damage, StringFormat=N0}" FontFamily="{StaticResource FontHead}" FontSize="15" Foreground="White" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="% Dano" Width="200">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="60"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Barra: estilo simples sem chrome do Windows (fundo escuro,
                                                     preenchimento dourado proporcional a DamagePctValue). -->
                                                <Border Grid.Column="0" Background="#242424" CornerRadius="3" Height="16" VerticalAlignment="Center">
                                                    <Border HorizontalAlignment="Left" Background="#c9a227" CornerRadius="3"
                                                            Width="{Binding DamagePctValue, Converter={StaticResource PctToWidth}}"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding DamagePct}" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="White"/>
                                            </Grid>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Cura" Width="100" DisplayMemberBinding="{Binding Healing}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Skill panel: overlay flutuante no canto direito -->
                    <Border x:Name="PanelDamageBySkill"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Width="282" Panel.ZIndex="10"
                            Background="#161616" BorderBrush="#2a1a06" BorderThickness="1"
                            CornerRadius="4" Padding="12" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="TxtDamageBySkillTitle" Grid.Row="0" Text="Dano por habilidade — selecione um jogador na lista"
                                       Foreground="#DEFFFFFF" FontWeight="SemiBold" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <ListView x:Name="ListDamageBySkill" Grid.Row="1" Background="Transparent" Foreground="White" BorderThickness="0">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Habilidade" Width="170" DisplayMemberBinding="{Binding Name}"/>
                                        <GridViewColumn Header="Dano" Width="80" DisplayMemberBinding="{Binding Damage}"/>
                                        <GridViewColumn Header="%" Width="60" DisplayMemberBinding="{Binding DamagePct}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Mostrado quando a conta de teste não tem permissão pra essa aba -->
            <Grid x:Name="PanelBlocked" Visibility="Collapsed" Background="#131313">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="600">
                    <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="VOCÊ ESTÁ BLOQUEADO DE ACESSAR ESSA PARTE!" Foreground="#dc2626"
                               FontFamily="{StaticResource FontHead}" FontSize="30" FontWeight="SemiBold"
                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,16,0,0"/>
                    <TextBlock Text="Fale com a liderança da guild se precisar de acesso." Foreground="#8CFFFFFF"
                               FontSize="13" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>

            <Grid x:Name="PanelFame" Visibility="Collapsed" Background="#131313">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Fama &amp; Prata" Foreground="#c9a227" FontFamily="{StaticResource FontHead}" FontSize="32" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtFameSessionStart" Foreground="#8CFFFFFF" FontSize="12" Margin="0,4,0,16" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Background="#1b1b1b" CornerRadius="6" Padding="22,16" Margin="0,0,12,0">
                            <StackPanel>
                                <Image Source="Icons/fame.png" Width="26" Height="26" HorizontalAlignment="Center"/>
                                <TextBlock Text="FAMA VERMELHA" Foreground="#8CFFFFFF" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                <TextBlock x:Name="TxtFameTotal" Text="0" Foreground="#f87171" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtFamePerHour" Text="0/hora" Foreground="#8CFFFFFF" FontSize="11" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1b1b1b" CornerRadius="6" Padding="22,16" Margin="0,0,12,0">
                            <StackPanel>
                                <Image Source="Icons/yellow_fame.png" Width="26" Height="26" HorizontalAlignment="Center"/>
                                <TextBlock Text="FAMA AMARELA" Foreground="#8CFFFFFF" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                <TextBlock x:Name="TxtYellowFameTotal" Text="—" Foreground="#fde047" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtYellowFamePerHour" Text="0/hora" Foreground="#8CFFFFFF" FontSize="11" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1b1b1b" CornerRadius="6" Padding="22,16" Margin="0,0,12,0">
                            <StackPanel>
                                <Image Source="Icons/silver.png" Width="26" Height="26" HorizontalAlignment="Center"/>
                                <TextBlock Text="PRATA" Foreground="#8CFFFFFF" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                <TextBlock x:Name="TxtSilverTotal" Text="0" Foreground="#e2e8f0" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtSilverPerHour" Text="0/hora" Foreground="#8CFFFFFF" FontSize="11" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Mobs mortos em mundo aberto (Task #2) — ver OpenWorldKillTracker.cs.
                             Conta pelo evento MobKilled (166), já calibrado, filtrando pelo
                             nome de quem deu o último hit = você. -->
                        <Border Background="#1b1b1b" CornerRadius="6" Padding="22,16">
                            <StackPanel>
                                <TextBlock Text="⚔️" FontSize="22" HorizontalAlignment="Center"/>
                                <TextBlock Text="MOBS MORTOS" Foreground="#8CFFFFFF" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                <TextBlock x:Name="TxtMobKillsTotal" Text="0" Foreground="#86efac" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtMobKillsPerHour" Text="0/hora" Foreground="#8CFFFFFF" FontSize="11" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <Button x:Name="BtnFameReset" Content="Reiniciar sessão" Click="BtnFameReset_Click"
                            Padding="14,6" Margin="0,20,0,0" Background="#2e2e2e" Foreground="White" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtFameHint" Foreground="#8CFFFFFF" FontSize="11" Margin="0,16,0,0" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="440"
                               Text="Fama amarela (facção/standing) ainda em calibração — me diga de qual conteúdo ela vem pra eu achar o código."/>

                    <!-- Gráfico da sessão: evolução acumulada de fama e prata, amostrada
                         a cada minuto (ver _sessionSamples). Cada série é normalizada ao
                         próprio máximo — o formato mostra ONDE o farm rendeu, não compara
                         valor absoluto de fama contra prata. -->
                    <Border x:Name="PanelSessionChart" Background="#1b1b1b" CornerRadius="6" Width="440"
                            Margin="0,20,0,0" Padding="12,10" Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="EVOLUÇÃO DA SESSÃO" Foreground="#8CFFFFFF" FontSize="10" FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Rectangle Width="10" Height="3" Fill="#f87171" VerticalAlignment="Center"/>
                                    <TextBlock Text="Fama" Foreground="#8CFFFFFF" FontSize="10" Margin="4,0,10,0"/>
                                    <Rectangle Width="10" Height="3" Fill="#e2e8f0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Prata" Foreground="#8CFFFFFF" FontSize="10" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Grid>
                            <Canvas x:Name="SessionChartCanvas" Height="90" Width="416" ClipToBounds="True"/>
                            <TextBlock x:Name="TxtSessionChartHint" Text="" Foreground="#57FFFFFF" FontSize="10" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Quebra de mobs mortos por tipo — só aparece depois do 1º kill. -->
                    <ListView x:Name="ListMobKills" Margin="0,20,0,0" MaxHeight="220" Width="440"
                              Background="#1b1b1b" Foreground="White" BorderThickness="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Mob" Width="280" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Mortes" Width="80" DisplayMemberBinding="{Binding Kills}"/>
                                <GridViewColumn Header="/hora" Width="70" DisplayMemberBinding="{Binding KillsPerHour}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </Grid>

            <!-- Histórico local de sessões (Task #8) — um resumo é gravado toda vez que
                 a captura é parada (ver SaveSessionToHistory em MainWindow.xaml.cs).
                 Só local (SessionHistoryStore.cs), nada é enviado pro servidor. -->
            <Grid x:Name="PanelSessions" Visibility="Collapsed" Background="#131313">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="16,12,16,8">
                    <TextBlock Text="Histórico de Sessões" Foreground="#c9a227" FontFamily="{StaticResource FontHead}" FontSize="26" FontWeight="SemiBold"/>
                    <TextBlock Foreground="#8CFFFFFF" FontSize="12" Margin="0,4,0,0"
                               Text="Um resumo é salvo automaticamente sempre que você para a captura. Só fica salvo neste computador."/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button x:Name="BtnExportSessionsCsv" Content="Exportar CSV" Click="BtnExportSessionsCsv_Click"
                                Padding="14,6" Background="#242424" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="BtnClearSessionHistory" Content="Limpar histórico" Click="BtnClearSessionHistory_Click"
                                Padding="14,6" Margin="8,0,0,0" Background="#2e2e2e" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <TextBlock x:Name="TxtSessionsStatus" Text="" Foreground="#8CFFFFFF" FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <ListView x:Name="ListSessionHistory" Grid.Row="1" Margin="16,0,16,16" Background="#1b1b1b" Foreground="White" BorderThickness="0" FontSize="13">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Período" Width="200" DisplayMemberBinding="{Binding Period}"/>
                            <GridViewColumn Header="Duração" Width="90" DisplayMemberBinding="{Binding Duration}"/>
                            <GridViewColumn Header="Fama" Width="100" DisplayMemberBinding="{Binding Fame}"/>
                            <GridViewColumn Header="Fama Amarela" Width="110" DisplayMemberBinding="{Binding YellowFame}"/>
                            <GridViewColumn Header="Prata" Width="110" DisplayMemberBinding="{Binding Silver}"/>
                            <GridViewColumn Header="Dano" Width="100" DisplayMemberBinding="{Binding Damage}"/>
                            <GridViewColumn Header="Itens de Loot" Width="100" DisplayMemberBinding="{Binding LootItems}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Grid>
        </Grid>

        <!-- Ícone da bandeja do sistema -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                         ToolTipText="XnoMercy"
                         IconSource="icon.ico"
                         TrayMouseDoubleClick="TrayIcon_DoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Abrir" Click="TrayIcon_DoubleClick"/>
                    <MenuItem Header="Sair" Click="TrayMenu_Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
