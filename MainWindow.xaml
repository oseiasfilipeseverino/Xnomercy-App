<Window x:Class="XnomercyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:local="clr-namespace:XnomercyApp"
        mc:Ignorable="d"
        Title="XnoMercy" Height="800" Width="1280"
        Background="#0a0a0a"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <Window.Resources>
        <Style TargetType="Button" x:Key="TabBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9ca3af"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barra de abas -->
        <Border Grid.Row="0" Background="#111111" BorderBrush="#262626" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="XNOMERCY" Foreground="#c9a227" FontWeight="Bold" FontSize="15"
                           Margin="16,0,24,0" VerticalAlignment="Center"/>
                <Button x:Name="BtnSite" Content="Site" Style="{StaticResource TabBtn}" Click="TabButton_Click" Tag="site" Foreground="White"/>
                <Button x:Name="BtnLoot" Content="Loot Log" Style="{StaticResource TabBtn}" Click="TabButton_Click" Tag="loot"/>
                <Button x:Name="BtnDamage" Content="Medidor de Dano" Style="{StaticResource TabBtn}" Click="TabButton_Click" Tag="damage"/>
                <Button x:Name="BtnFame" Content="Fama &amp; Prata" Style="{StaticResource TabBtn}" Click="TabButton_Click" Tag="fame"/>
            </StackPanel>
        </Border>

        <!-- Conteúdo -->
        <Grid Grid.Row="1">
            <wv2:WebView2 x:Name="WebView" Visibility="Visible"/>

            <Grid x:Name="PanelLoot" Visibility="Collapsed" Background="#0a0a0a">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="16,12,16,8">
                    <TextBlock Text="Loot Log — modo calibração" Foreground="#c9a227" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Foreground="#9ca3af" FontSize="12" Margin="0,4,0,8" TextWrapping="Wrap"
                               Text="Mostrando todos os eventos de rede decodificados (ainda não filtrados por tipo). Jogue uma sessão curta — pegar item do chão, abrir baú — e observe qual 'Code' aparece nesses momentos, pra calibrarmos o filtro de loot."/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnCaptureToggle" Content="Iniciar captura" Click="BtnCaptureToggle_Click"
                                Padding="14,6" Background="#c0392b" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <TextBlock x:Name="TxtCaptureStatus" Text="Parado" Foreground="#9ca3af" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="Amostra hex (primeiros pacotes UDP, 64 bytes):" Foreground="#9ca3af" FontSize="11" Margin="0,10,0,2"/>
                    <TextBox x:Name="TxtHexSample" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas"
                             FontSize="11" Background="#111111" Foreground="#7dd3fc" BorderThickness="0" MaxHeight="100"/>
                </StackPanel>
                <ListView x:Name="ListLootEvents" Grid.Row="1" Margin="16,0,16,16" Background="#111111" Foreground="White" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Hora" Width="90" DisplayMemberBinding="{Binding Time}"/>
                            <GridViewColumn Header="Code" Width="60" DisplayMemberBinding="{Binding Code}"/>
                            <GridViewColumn Header="Parâmetros" Width="900" DisplayMemberBinding="{Binding Summary}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>

            <Grid x:Name="PanelDamage" Visibility="Collapsed" Background="#0a0a0a">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="16,12,16,8">
                    <TextBlock Text="Medidor de Dano — sessão atual" Foreground="#c9a227" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Foreground="#9ca3af" FontSize="12" Margin="0,4,0,8" TextWrapping="Wrap"
                               Text="Ranking de dano e cura por jogador. Aguardando calibração dos códigos de evento (ver Network/GameEventCodes.cs) — fica zerado até lá, é esperado."/>
                    <Button x:Name="BtnDamageReset" Content="Reiniciar sessão" Click="BtnDamageReset_Click"
                            Padding="14,6" Background="#262626" Foreground="White" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left"/>
                </StackPanel>
                <ListView x:Name="ListDamage" Grid.Row="1" Margin="16,0,16,16" Background="#111111" Foreground="White" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Jogador" Width="300" DisplayMemberBinding="{Binding PlayerKey}"/>
                            <GridViewColumn Header="Dano" Width="150" DisplayMemberBinding="{Binding Damage}"/>
                            <GridViewColumn Header="Cura" Width="150" DisplayMemberBinding="{Binding Healing}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>

            <Grid x:Name="PanelFame" Visibility="Collapsed" Background="#0a0a0a">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Fama &amp; Prata" Foreground="#c9a227" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtFameSessionStart" Foreground="#9ca3af" FontSize="12" Margin="0,4,0,16" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Background="#111111" CornerRadius="6" Padding="24,16" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="FAMA GANHA" Foreground="#9ca3af" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtFameTotal" Text="0" Foreground="#7dd3fc" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#111111" CornerRadius="6" Padding="24,16">
                            <StackPanel>
                                <TextBlock Text="PRATA GANHA" Foreground="#9ca3af" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtSilverTotal" Text="0" Foreground="#facc15" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <Button x:Name="BtnFameReset" Content="Reiniciar sessão" Click="BtnFameReset_Click"
                            Padding="14,6" Margin="0,20,0,0" Background="#262626" Foreground="White" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center"/>
                    <TextBlock Foreground="#6b7280" FontSize="11" Margin="0,16,0,0" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="420"
                               Text="Aguardando calibração dos códigos de evento (ver Network/GameEventCodes.cs) — fica zerado até lá, é esperado."/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Ícone da bandeja do sistema -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                         ToolTipText="XnoMercy"
                         IconSource="icon.ico"
                         TrayMouseDoubleClick="TrayIcon_DoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Abrir" Click="TrayIcon_DoubleClick"/>
                    <MenuItem Header="Sair" Click="TrayMenu_Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
